<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Teaching Practices Inventory</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="min-h-screen bg-slate-50 p-8 text-slate-900">

    <div class="mx-auto max-w-6xl">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold">Faculty Submissions</h1>
                <p class="text-slate-500 mt-1">Teaching Practices Inventory Results</p>
            </div>
            <div class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white">
                Total Submissions: <%= responses.length %>
            </div>
        </div>

        <div class="grid gap-6">
            <% if (responses.length===0) { %>
                <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-500">
                    No responses submitted yet.
                </div>
                <% } else { %>
                    <% responses.forEach(function(response) { %>
                        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">

                            <div class="flex flex-wrap items-center justify-between p-6">
                                <div class="grid grid-cols-2 gap-x-8 gap-y-2 sm:grid-cols-4">
                                    <div>
                                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Name
                                        </div>
                                        <div class="mt-1 font-medium">
                                            <%= response.name || 'Anonymous' %>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                                            Department</div>
                                        <div class="mt-1 font-medium">
                                            <%= response.department || 'N/A' %>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                                            Experience</div>
                                        <div class="mt-1 font-medium">
                                            <%= response.experience || 'N/A' %>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Date
                                        </div>
                                        <div class="mt-1 text-sm text-slate-600">
                                            <%= new Date(response.created_at).toLocaleDateString() %>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 flex items-center gap-4 sm:mt-0">
                                    <div class="text-right">
                                        <div class="text-2xl font-bold text-slate-900">
                                            <%= response.total_score %> <span
                                                    class="text-sm font-normal text-slate-500">/ 230</span>
                                        </div>
                                        <div class="text-sm font-medium text-blue-600">
                                            <%= response.readiness_level %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <details
                                class="group border-t border-slate-100 p-6 [&_summary::-webkit-details-marker]:hidden">
                                <summary
                                    class="flex cursor-pointer items-center text-sm font-medium text-slate-600 hover:text-slate-900 focus:outline-none">
                                    <span class="mr-2">View Exact Answers</span>
                                    <svg class="h-4 w-4 transition duration-300 group-open:-rotate-180"
                                        xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </summary>
                                <div
                                    class="mt-4 grid grid-cols-1 gap-2 rounded-xl bg-slate-50 p-4 sm:grid-cols-2 md:grid-cols-3">
                                    <% for (const [qId, answer] of Object.entries(response.answers)) { %>
                                        <div class="rounded-lg border border-slate-200 bg-white p-3 text-sm shadow-sm">
                                            <span class="font-bold text-slate-500">
                                                <%= qId.toUpperCase() %>:
                                            </span>
                                            <span class="text-slate-800">
                                                <%= answer %>
                                            </span>
                                        </div>
                                        <% } %>
                                </div>
                            </details>

                        </div>
                        <% }) %>
                            <% } %>
        </div>
    </div>

</body>

</html>